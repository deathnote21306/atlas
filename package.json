{
  "name": "atlas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev:web": "pnpm --filter @atlas/web dev",
    "build:types": "uv run python packages/schemas/scripts/generate_ts.py",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
